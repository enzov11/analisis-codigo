# Obligatorio solo para entrenamiento
DATASET_PATH=/ruta/al/dataset
TARGET_CWE_IDS=CWE23,CWE36,CWE78,CWE80,CWE89,CWE90,CWE113,CWE129,CWE134,CWE190,CWE319,CWE400,CWE470,CWE601,CWE643

# Artefactos del pipeline
# Si se define, los paths por defecto se guardan en src/models/<version>/
ARTIFACT_VERSION=cwe15-roadmap-v1
# Descomentar solo para reemplazar las rutas versionadas por defecto.
# MODEL_SAVE_PATH=src/models/vuldeepecker.keras
# TOKENIZER_SAVE_PATH=src/models/tokenizer.pkl
# CWE_ENCODER_SAVE_PATH=src/models/cwe_encoder.pkl
# METADATA_SAVE_PATH=src/models/metadata.json
# EVALUATION_SAVE_PATH=src/models/evaluation.json
# LOG_DIR=src/logs/training

# Preprocesamiento
MAX_CODE_LENGTH=500
MAX_TOKENS=20000
TOKENIZER_OOV_TOKEN=<OOV>

# Modelo
EMBEDDING_DIM=256
LSTM_UNITS=128
DENSE_UNITS=64
DROPOUT_RATE=0.3
LEARNING_RATE=0.001

# Entrenamiento
TRAINING_PROFILE=final
BATCH_SIZE=32
EPOCHS=15
TRAIN_SPLIT=0.7
VALIDATION_SPLIT=0.15
TEST_SPLIT=0.15
RANDOM_SEED=42
BALANCE_DATASET=True
MAX_OVERSAMPLE_MULTIPLIER=2.0
REQUIRE_ALL_TARGET_CWES=True
TRAINING_VERBOSE=1
MAX_SAMPLES_PER_CWE=
EARLY_STOPPING_PATIENCE=3
EARLY_STOPPING_MIN_DELTA=0.001
EARLY_STOPPING_MONITOR=val_main_loss
EARLY_STOPPING_MODE=min
CHECKPOINT_MONITOR=val_main_loss
CHECKPOINT_MODE=min
TENSORBOARD_HISTOGRAM_FREQ=0

# Inferencia
PREDICTION_THRESHOLD=0.5
