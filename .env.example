# Obligatorio solo para entrenamiento
DATASET_PATH=/ruta/al/dataset
TARGET_CWE_IDS=CWE78,CWE89,CWE90

# Artefactos del pipeline
# Si se define, los paths por defecto se guardan en src/models/<version>/
ARTIFACT_VERSION=cwe78-cwe89-cwe90-v1
# Descomentar solo para reemplazar las rutas versionadas por defecto.
# MODEL_SAVE_PATH=src/models/vuldeepecker.keras
# TOKENIZER_SAVE_PATH=src/models/tokenizer.pkl
# CWE_ENCODER_SAVE_PATH=src/models/cwe_encoder.pkl
# METADATA_SAVE_PATH=src/models/metadata.json
# EVALUATION_SAVE_PATH=src/models/evaluation.json
# LOG_DIR=src/logs/training

# Preprocesamiento
MAX_CODE_LENGTH=500
MAX_TOKENS=20000
TOKENIZER_OOV_TOKEN=<OOV>

# Modelo
EMBEDDING_DIM=256
LSTM_UNITS=128
DENSE_UNITS=64
DROPOUT_RATE=0.3
LEARNING_RATE=0.001

# Entrenamiento
BATCH_SIZE=32
EPOCHS=15
TRAIN_SPLIT=0.7
VALIDATION_SPLIT=0.15
TEST_SPLIT=0.15
RANDOM_SEED=42
BALANCE_DATASET=True
MAX_OVERSAMPLE_MULTIPLIER=2.0
REQUIRE_ALL_TARGET_CWES=True
TRAINING_VERBOSE=1

# Inferencia
PREDICTION_THRESHOLD=0.5
